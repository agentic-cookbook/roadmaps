#!/usr/bin/env python3
"""Progress dashboard CLI helper.

Manages the lifecycle of a progress dashboard: init, update steps,
check user controls, and shutdown. Persists state in the dashboard
directory so each invocation is stateless from the caller's perspective.

Usage:
    dash init <title> <step1_name> [step2_name ...]
    dash step-start <step_number>
    dash step-detail <step_number> <detail_text>
    dash step-link <step_number> <label> <url>
    dash step-complete <step_number>
    dash step-error <step_number> <error_message>
    dash event <message>
    dash check-control
    dash complete
    dash error <message>
    dash shutdown
    dash dir

All step numbers are 1-based.

The 'init' command creates the temp directory, copies in the HTML and
server, starts the server, opens the browser, and writes the initial
progress.json. It prints the DASH_DIR path to stdout.

Subsequent commands find the dashboard via a state file at
$TMPDIR/progress-dashboard-active (or /tmp/progress-dashboard-active).
"""

import json
import os
import platform
import re
import shutil
import signal
import socket
import subprocess
import sys
import time
from datetime import datetime, timezone
from pathlib import Path


def slugify(name):
    """Convert a feature name to a filesystem-safe slug."""
    return re.sub(r"[^a-zA-Z0-9_-]", "-", name).strip("-").lower()


def dash_dir_for(title):
    """Deterministic dashboard directory based on feature name."""
    tmpdir = Path(os.environ.get("TMPDIR", "/tmp")).resolve()
    return tmpdir / f"progress-dashboard-{slugify(title)}"


def state_file():
    return Path(os.environ.get("TMPDIR", "/tmp")).resolve() / "progress-dashboard-active"


def save_state(dash_dir, pid, port):
    state_file().write_text(json.dumps({
        "dash_dir": str(dash_dir),
        "pid": pid,
        "port": port,
    }))


def load_state():
    sf = state_file()
    if not sf.exists():
        return None
    try:
        return json.loads(sf.read_text())
    except (json.JSONDecodeError, OSError):
        return None


def get_dash_dir():
    state = load_state()
    if not state:
        print("ERROR: No active dashboard. Run 'dash init' first.", file=sys.stderr)
        sys.exit(1)
    return Path(state["dash_dir"])


def now_iso():
    return datetime.now(timezone.utc).isoformat(timespec="seconds")


def read_progress(dash_dir):
    p = dash_dir / "progress.json"
    if not p.exists():
        return None
    try:
        return json.loads(p.read_text())
    except (json.JSONDecodeError, OSError):
        return None


def write_progress(dash_dir, data):
    data["updated_at"] = now_iso()
    (dash_dir / "progress.json").write_text(json.dumps(data, indent=2))


def add_event(data, message):
    if "events" not in data:
        data["events"] = []
    data["events"].append({"time": now_iso(), "message": message})


def find_skill_references():
    """Find the progress-dashboard skill references directory."""
    search_paths = [
        Path.home() / ".claude" / "skills" / "progress-dashboard" / "references",
    ]
    # Also check if we're in the repo itself
    script_dir = Path(__file__).resolve().parent
    if script_dir.name == "references":
        search_paths.insert(0, script_dir)

    for p in search_paths:
        if (p / "dashboard.html").exists() and (p / "server.py").exists():
            return p
    return None


def find_free_port():
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
        s.bind(("", 0))
        return s.getsockname()[1]


def detect_environment():
    """Auto-detect machine, repo, and worktree info."""
    env = {}

    # Machine name
    env["machine"] = platform.node() or os.environ.get("HOSTNAME", "unknown")

    # Git repo
    try:
        remote = subprocess.check_output(
            ["git", "remote", "get-url", "origin"],
            stderr=subprocess.DEVNULL, text=True
        ).strip()
        # Extract org/repo from URL
        # Handles: git@github.com:org/repo.git, https://github.com/org/repo.git
        if ":" in remote and "@" in remote:
            repo = remote.split(":")[-1]
        else:
            repo = "/".join(remote.rstrip("/").split("/")[-2:])
        env["repo"] = repo.removesuffix(".git")
        env["repo_url"] = remote.removesuffix(".git")
        if env["repo_url"].startswith("git@"):
            # Convert git@github.com:org/repo to https://github.com/org/repo
            env["repo_url"] = "https://" + env["repo_url"][4:].replace(":", "/", 1)
    except (subprocess.CalledProcessError, OSError):
        env["repo"] = os.path.basename(os.getcwd())
        env["repo_url"] = None

    # Branch
    try:
        env["branch"] = subprocess.check_output(
            ["git", "rev-parse", "--abbrev-ref", "HEAD"],
            stderr=subprocess.DEVNULL, text=True
        ).strip()
    except (subprocess.CalledProcessError, OSError):
        env["branch"] = None

    # Worktree — detect if we're in one
    try:
        git_dir = subprocess.check_output(
            ["git", "rev-parse", "--git-dir"],
            stderr=subprocess.DEVNULL, text=True
        ).strip()
        toplevel = subprocess.check_output(
            ["git", "rev-parse", "--show-toplevel"],
            stderr=subprocess.DEVNULL, text=True
        ).strip()
        if "/worktrees/" in git_dir:
            env["worktree"] = os.path.basename(toplevel)
        else:
            env["worktree"] = None
    except (subprocess.CalledProcessError, OSError):
        env["worktree"] = None

    return env


def cmd_init(args):
    if len(args) < 1:
        print("Usage: dash init <title> [step1 step2 ...]", file=sys.stderr)
        sys.exit(1)

    title = args[0]
    step_names = args[1:] if len(args) > 1 else []

    # Kill any existing dashboard server and wait for it to die so the port is freed
    existing = load_state()
    if existing:
        try:
            os.kill(existing["pid"], signal.SIGTERM)
            for _ in range(20):
                time.sleep(0.1)
                try:
                    os.kill(existing["pid"], 0)
                except ProcessLookupError:
                    break
            else:
                try:
                    os.kill(existing["pid"], signal.SIGKILL)
                    time.sleep(0.1)
                except (OSError, ProcessLookupError):
                    pass
        except (OSError, ProcessLookupError):
            pass

    # Find skill references
    refs = find_skill_references()
    if not refs:
        print("ERROR: Cannot find progress-dashboard references (dashboard.html, server.py)", file=sys.stderr)
        sys.exit(1)

    # Use deterministic directory based on feature name
    dash_dir = dash_dir_for(title)
    reusing = dash_dir.exists() and (dash_dir / "progress.json").exists()
    dash_dir.mkdir(parents=True, exist_ok=True)

    # Always copy latest assets (they may have been updated)
    shutil.copy2(refs / "dashboard.html", dash_dir / "index.html")
    shutil.copy2(refs / "server.py", dash_dir / "server.py")

    # Reuse existing progress.json or create fresh
    if reusing:
        data = read_progress(dash_dir)
        data["status"] = "running"
        data["title"] = title
        data.pop("control_state", None)
        data["events"] = [{"time": now_iso(), "message": "Dashboard restarted"}]
        write_progress(dash_dir, data)
        print(f"Reusing existing dashboard for {title}", file=sys.stderr)
    else:
        env = detect_environment()
        data = {
            "title": title,
            "status": "running",
            "environment": env,
            "issues": [],
            "prs": [],
            "steps": [
                {
                    "name": name,
                    "status": "not_started",
                    "detail": None,
                    "links": [],
                    "started_at": None,
                    "completed_at": None,
                    "updated_at": None,
                }
                for name in step_names
            ],
            "events": [{"time": now_iso(), "message": "Dashboard started"}],
            "updated_at": now_iso(),
        }
        write_progress(dash_dir, data)

    # Clear stale control state from previous run
    (dash_dir / "control.json").unlink(missing_ok=True)

    # Reuse previous port from the port file, or fall back to the global
    # state file. Only pick a new port on the very first run for this title.
    # No bind test needed — we already waited for the old server to die.
    port = None
    port_file = dash_dir / "port"
    if port_file.exists():
        try:
            port = int(port_file.read_text().strip())
        except (ValueError, OSError):
            port = None
    if not port:
        port = existing.get("port") if existing and str(dash_dir) == existing.get("dash_dir") else None
    if not port:
        port = find_free_port()
    # Persist port inside the dashboard directory for future runs
    port_file.write_text(str(port))
    proc = subprocess.Popen(
        [sys.executable, str(dash_dir / "server.py"), str(port), str(dash_dir)],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )

    # Save state right away so subsequent commands work
    save_state(dash_dir, proc.pid, port)

    # Open browser immediately — the HTML page handles waiting for data
    url = f"http://127.0.0.1:{port}"
    if sys.platform == "darwin":
        subprocess.Popen(["open", url], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    elif shutil.which("xdg-open"):
        subprocess.Popen(["xdg-open", url], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

    # Quick check — if server died instantly, warn but don't block
    time.sleep(0.2)
    if proc.poll() is not None:
        print("WARNING: Server may have failed to start", file=sys.stderr)

    # Print info for caller
    print(f"{dash_dir}")


def cmd_set_steps(args):
    if len(args) < 1:
        print("Usage: dash set-steps <step1> [step2 ...]", file=sys.stderr)
        sys.exit(1)
    dash_dir = get_dash_dir()
    data = read_progress(dash_dir)
    if not data:
        sys.exit(1)

    data["steps"] = [
        {
            "name": name,
            "status": "not_started",
            "detail": None,
            "links": [],
            "started_at": None,
            "completed_at": None,
            "updated_at": None,
        }
        for name in args
    ]
    add_event(data, f"Loaded {len(args)} steps")
    write_progress(dash_dir, data)


def get_step(data, step_num):
    idx = step_num - 1
    if idx < 0 or idx >= len(data.get("steps", [])):
        print(f"ERROR: Step {step_num} out of range (1-{len(data.get('steps', []))})", file=sys.stderr)
        sys.exit(1)
    return data["steps"][idx], idx


def cmd_step_start(args):
    if len(args) < 1:
        print("Usage: dash step-start <step_number>", file=sys.stderr)
        sys.exit(1)
    dash_dir = get_dash_dir()
    data = read_progress(dash_dir)
    if not data:
        print("ERROR: No progress.json found", file=sys.stderr)
        sys.exit(1)

    step_num = int(args[0])
    step, _ = get_step(data, step_num)
    step["status"] = "in_progress"
    step["started_at"] = now_iso()
    step["updated_at"] = now_iso()
    add_event(data, f"Step {step_num} started: {step['name']}")
    write_progress(dash_dir, data)


