def cmd_check_control(args):
    dash_dir = get_dash_dir()
    control_file = dash_dir / "control.json"
    if not control_file.exists():
        print("none")
        return

    try:
        control = json.loads(control_file.read_text())
        action = control.get("action", "none")
        print(action)
        if action != "none":
            data = read_progress(dash_dir)
            if data:
                labels = {"pause": "Pause", "resume": "Resume", "stop": "Stop"}
                add_event(data, f"{labels.get(action, action)} received by agent")
                data["control_state"] = action
                write_progress(dash_dir, data)
        if action == "resume":
            control_file.unlink(missing_ok=True)
    except (json.JSONDecodeError, OSError):
        print("none")


def cmd_complete(args):
    dash_dir = get_dash_dir()
    data = read_progress(dash_dir)
    if not data:
        sys.exit(1)

    data["status"] = "complete"
    for step in data.get("steps", []):
        if step["status"] == "in_progress":
            step["status"] = "complete"
            step["updated_at"] = now_iso()
    add_event(data, "All steps complete")
    write_progress(dash_dir, data)


def cmd_error(args):
    dash_dir = get_dash_dir()
    data = read_progress(dash_dir)
    if not data:
        sys.exit(1)

    message = " ".join(args) if args else "Unknown error"
    data["status"] = "error"
    add_event(data, f"Error: {message}")
    write_progress(dash_dir, data)


def cmd_shutdown(args):
    state = load_state()
    if not state:
        print("No active dashboard to shut down.")
        return

    try:
        os.kill(state["pid"], signal.SIGTERM)
    except (OSError, ProcessLookupError):
        pass

    state_file().unlink(missing_ok=True)
    print(f"Dashboard shut down (was at {state['dash_dir']})")


def cmd_dir(args):
    state = load_state()
    if not state:
        print("ERROR: No active dashboard", file=sys.stderr)
        sys.exit(1)
    print(state["dash_dir"])


def cmd_add_issue(args):
    if len(args) < 3:
        print("Usage: dash add-issue <number> <title> <url>", file=sys.stderr)
        sys.exit(1)
    dash_dir = get_dash_dir()
    data = read_progress(dash_dir)
    if not data:
        sys.exit(1)

    number = int(args[0])
    title = args[1]
    url = args[2]
    if "issues" not in data:
        data["issues"] = []
    # Update if exists, otherwise add
    for issue in data["issues"]:
        if issue["number"] == number:
            issue["title"] = title
            issue["url"] = url
            write_progress(dash_dir, data)
            return
    data["issues"].append({
        "number": number,
        "title": title,
        "url": url,
        "status": "open",
    })
    write_progress(dash_dir, data)


