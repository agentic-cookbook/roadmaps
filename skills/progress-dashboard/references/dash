#!/usr/bin/env python3
"""Progress dashboard CLI helper.

Manages the lifecycle of a progress dashboard: init, update steps,
check user controls, and shutdown. Persists state in the dashboard
directory so each invocation is stateless from the caller's perspective.

Usage:
    dash init <title> <step1_name> [step2_name ...]
    dash step-start <step_number>
    dash step-detail <step_number> <detail_text>
    dash step-link <step_number> <label> <url>
    dash step-complete <step_number>
    dash step-error <step_number> <error_message>
    dash event <message>
    dash check-control
    dash complete
    dash error <message>
    dash shutdown
    dash dir

All step numbers are 1-based.

The 'init' command creates the temp directory, copies in the HTML and
server, starts the server, opens the browser, and writes the initial
progress.json. It prints the DASH_DIR path to stdout.

Subsequent commands find the dashboard via a state file at
$TMPDIR/progress-dashboard-active (or /tmp/progress-dashboard-active).
"""

import json
import os
import platform
import shutil
import signal
import socket
import subprocess
import sys
import tempfile
import time
from datetime import datetime, timezone
from pathlib import Path


def state_file():
    return Path(os.environ.get("TMPDIR", "/tmp")) / "progress-dashboard-active"


def save_state(dash_dir, pid, port):
    state_file().write_text(json.dumps({
        "dash_dir": str(dash_dir),
        "pid": pid,
        "port": port,
    }))


def load_state():
    sf = state_file()
    if not sf.exists():
        return None
    try:
        return json.loads(sf.read_text())
    except (json.JSONDecodeError, OSError):
        return None


def get_dash_dir():
    state = load_state()
    if not state:
        print("ERROR: No active dashboard. Run 'dash init' first.", file=sys.stderr)
        sys.exit(1)
    return Path(state["dash_dir"])


def now_iso():
    return datetime.now(timezone.utc).isoformat(timespec="seconds")


def read_progress(dash_dir):
    p = dash_dir / "progress.json"
    if not p.exists():
        return None
    try:
        return json.loads(p.read_text())
    except (json.JSONDecodeError, OSError):
        return None


def write_progress(dash_dir, data):
    data["updated_at"] = now_iso()
    (dash_dir / "progress.json").write_text(json.dumps(data, indent=2))


def add_event(data, message):
    if "events" not in data:
        data["events"] = []
    data["events"].append({"time": now_iso(), "message": message})


def find_skill_references():
    """Find the progress-dashboard skill references directory."""
    search_paths = [
        Path.home() / ".claude" / "skills" / "progress-dashboard" / "references",
    ]
    # Also check if we're in the repo itself
    script_dir = Path(__file__).resolve().parent
    if script_dir.name == "references":
        search_paths.insert(0, script_dir)

    for p in search_paths:
        if (p / "dashboard.html").exists() and (p / "server.py").exists():
            return p
    return None


def find_free_port():
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
        s.bind(("", 0))
        return s.getsockname()[1]


def detect_environment():
    """Auto-detect machine, repo, and worktree info."""
    env = {}

    # Machine name
    env["machine"] = platform.node() or os.environ.get("HOSTNAME", "unknown")

    # Git repo
    try:
        remote = subprocess.check_output(
            ["git", "remote", "get-url", "origin"],
            stderr=subprocess.DEVNULL, text=True
        ).strip()
        # Extract org/repo from URL
        # Handles: git@github.com:org/repo.git, https://github.com/org/repo.git
        if ":" in remote and "@" in remote:
            repo = remote.split(":")[-1]
        else:
            repo = "/".join(remote.rstrip("/").split("/")[-2:])
        env["repo"] = repo.removesuffix(".git")
        env["repo_url"] = remote.removesuffix(".git")
        if env["repo_url"].startswith("git@"):
            # Convert git@github.com:org/repo to https://github.com/org/repo
            env["repo_url"] = "https://" + env["repo_url"][4:].replace(":", "/", 1)
    except (subprocess.CalledProcessError, OSError):
        env["repo"] = os.path.basename(os.getcwd())
        env["repo_url"] = None

    # Branch
    try:
        env["branch"] = subprocess.check_output(
            ["git", "rev-parse", "--abbrev-ref", "HEAD"],
            stderr=subprocess.DEVNULL, text=True
        ).strip()
    except (subprocess.CalledProcessError, OSError):
        env["branch"] = None

    # Worktree — detect if we're in one
    try:
        git_dir = subprocess.check_output(
            ["git", "rev-parse", "--git-dir"],
            stderr=subprocess.DEVNULL, text=True
        ).strip()
        toplevel = subprocess.check_output(
            ["git", "rev-parse", "--show-toplevel"],
            stderr=subprocess.DEVNULL, text=True
        ).strip()
        if "/worktrees/" in git_dir:
            env["worktree"] = os.path.basename(toplevel)
        else:
            env["worktree"] = None
    except (subprocess.CalledProcessError, OSError):
        env["worktree"] = None

    return env


def cmd_init(args):
    if len(args) < 1:
        print("Usage: dash init <title> [step1 step2 ...]", file=sys.stderr)
        sys.exit(1)

    title = args[0]
    step_names = args[1:] if len(args) > 1 else []

    # Check for existing dashboard
    existing = load_state()
    if existing and Path(existing["dash_dir"]).exists():
        print(f"WARNING: Dashboard already active at {existing['dash_dir']}", file=sys.stderr)
        print("Run 'dash shutdown' first, or it will be replaced.", file=sys.stderr)
        try:
            os.kill(existing["pid"], signal.SIGTERM)
        except (OSError, ProcessLookupError):
            pass

    # Find skill references
    refs = find_skill_references()
    if not refs:
        print("ERROR: Cannot find progress-dashboard references (dashboard.html, server.py)", file=sys.stderr)
        sys.exit(1)

    # Create temp directory
    dash_dir = Path(tempfile.mkdtemp(prefix="progress-dashboard-"))

    # Copy assets
    shutil.copy2(refs / "dashboard.html", dash_dir / "index.html")
    shutil.copy2(refs / "server.py", dash_dir / "server.py")

    # Auto-detect environment
    env = detect_environment()

    # Write initial progress.json
    data = {
        "title": title,
        "status": "running",
        "environment": env,
        "issues": [],
        "prs": [],
        "steps": [
            {
                "name": name,
                "status": "not_started",
                "detail": None,
                "links": [],
                "started_at": None,
                "completed_at": None,
                "updated_at": None,
            }
            for name in step_names
        ],
        "events": [{"time": now_iso(), "message": "Dashboard started"}],
        "updated_at": now_iso(),
    }
    write_progress(dash_dir, data)

    # Start server and open browser immediately — don't wait for verification
    port = find_free_port()
    proc = subprocess.Popen(
        [sys.executable, str(dash_dir / "server.py"), str(port), str(dash_dir)],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )

    # Save state right away so subsequent commands work
    save_state(dash_dir, proc.pid, port)

    # Open browser immediately — the HTML page handles waiting for data
    url = f"http://127.0.0.1:{port}"
    if sys.platform == "darwin":
        subprocess.Popen(["open", url], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    elif shutil.which("xdg-open"):
        subprocess.Popen(["xdg-open", url], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

    # Quick check — if server died instantly, warn but don't block
    time.sleep(0.2)
    if proc.poll() is not None:
        print("WARNING: Server may have failed to start", file=sys.stderr)

    # Print info for caller
    print(f"{dash_dir}")


def cmd_set_steps(args):
    if len(args) < 1:
        print("Usage: dash set-steps <step1> [step2 ...]", file=sys.stderr)
        sys.exit(1)
    dash_dir = get_dash_dir()
    data = read_progress(dash_dir)
    if not data:
        sys.exit(1)

    data["steps"] = [
        {
            "name": name,
            "status": "not_started",
            "detail": None,
            "links": [],
            "started_at": None,
            "completed_at": None,
            "updated_at": None,
        }
        for name in args
    ]
    add_event(data, f"Loaded {len(args)} steps")
    write_progress(dash_dir, data)


def get_step(data, step_num):
    idx = step_num - 1
    if idx < 0 or idx >= len(data.get("steps", [])):
        print(f"ERROR: Step {step_num} out of range (1-{len(data.get('steps', []))})", file=sys.stderr)
        sys.exit(1)
    return data["steps"][idx], idx


def cmd_step_start(args):
    if len(args) < 1:
        print("Usage: dash step-start <step_number>", file=sys.stderr)
        sys.exit(1)
    dash_dir = get_dash_dir()
    data = read_progress(dash_dir)
    if not data:
        print("ERROR: No progress.json found", file=sys.stderr)
        sys.exit(1)

    step_num = int(args[0])
    step, _ = get_step(data, step_num)
    step["status"] = "in_progress"
    step["started_at"] = now_iso()
    step["updated_at"] = now_iso()
    add_event(data, f"Step {step_num} started: {step['name']}")
    write_progress(dash_dir, data)


def cmd_step_detail(args):
    if len(args) < 2:
        print("Usage: dash step-detail <step_number> <detail>", file=sys.stderr)
        sys.exit(1)
    dash_dir = get_dash_dir()
    data = read_progress(dash_dir)
    if not data:
        sys.exit(1)

    step_num = int(args[0])
    detail = " ".join(args[1:])
    step, _ = get_step(data, step_num)
    step["detail"] = detail
    step["updated_at"] = now_iso()
    write_progress(dash_dir, data)


def cmd_step_link(args):
    if len(args) < 3:
        print("Usage: dash step-link <step_number> <label> <url>", file=sys.stderr)
        sys.exit(1)
    dash_dir = get_dash_dir()
    data = read_progress(dash_dir)
    if not data:
        sys.exit(1)

    step_num = int(args[0])
    label = args[1]
    url = args[2]
    step, _ = get_step(data, step_num)
    step["links"].append({"label": label, "url": url})
    step["updated_at"] = now_iso()
    add_event(data, f"Step {step_num}: {label}")
    write_progress(dash_dir, data)


def cmd_step_complete(args):
    if len(args) < 1:
        print("Usage: dash step-complete <step_number>", file=sys.stderr)
        sys.exit(1)
    dash_dir = get_dash_dir()
    data = read_progress(dash_dir)
    if not data:
        sys.exit(1)

    step_num = int(args[0])
    step, _ = get_step(data, step_num)
    step["status"] = "complete"
    step["completed_at"] = now_iso()
    step["updated_at"] = now_iso()
    add_event(data, f"Step {step_num} complete: {step['name']}")
    write_progress(dash_dir, data)


def cmd_step_error(args):
    if len(args) < 2:
        print("Usage: dash step-error <step_number> <message>", file=sys.stderr)
        sys.exit(1)
    dash_dir = get_dash_dir()
    data = read_progress(dash_dir)
    if not data:
        sys.exit(1)

    step_num = int(args[0])
    message = " ".join(args[1:])
    step, _ = get_step(data, step_num)
    step["status"] = "error"
    step["detail"] = message
    step["updated_at"] = now_iso()
    data["status"] = "error"
    add_event(data, f"Step {step_num} error: {message}")
    write_progress(dash_dir, data)


def cmd_event(args):
    if len(args) < 1:
        print("Usage: dash event <message>", file=sys.stderr)
        sys.exit(1)
    dash_dir = get_dash_dir()
    data = read_progress(dash_dir)
    if not data:
        sys.exit(1)

    add_event(data, " ".join(args))
    write_progress(dash_dir, data)


def cmd_check_control(args):
    dash_dir = get_dash_dir()
    control_file = dash_dir / "control.json"
    if not control_file.exists():
        print("none")
        return

    try:
        control = json.loads(control_file.read_text())
        action = control.get("action", "none")
        print(action)
        if action != "none":
            data = read_progress(dash_dir)
            if data:
                labels = {"pause": "Pause", "resume": "Resume", "stop": "Stop"}
                add_event(data, f"{labels.get(action, action)} received by agent")
                data["control_state"] = action
                write_progress(dash_dir, data)
        if action == "resume":
            control_file.unlink(missing_ok=True)
    except (json.JSONDecodeError, OSError):
        print("none")


def cmd_complete(args):
    dash_dir = get_dash_dir()
    data = read_progress(dash_dir)
    if not data:
        sys.exit(1)

    data["status"] = "complete"
    for step in data.get("steps", []):
        if step["status"] == "in_progress":
            step["status"] = "complete"
            step["updated_at"] = now_iso()
    add_event(data, "All steps complete")
    write_progress(dash_dir, data)


def cmd_error(args):
    dash_dir = get_dash_dir()
    data = read_progress(dash_dir)
    if not data:
        sys.exit(1)

    message = " ".join(args) if args else "Unknown error"
    data["status"] = "error"
    add_event(data, f"Error: {message}")
    write_progress(dash_dir, data)


def cmd_shutdown(args):
    state = load_state()
    if not state:
        print("No active dashboard to shut down.")
        return

    try:
        os.kill(state["pid"], signal.SIGTERM)
    except (OSError, ProcessLookupError):
        pass

    state_file().unlink(missing_ok=True)
    print(f"Dashboard shut down (was at {state['dash_dir']})")


def cmd_dir(args):
    state = load_state()
    if not state:
        print("ERROR: No active dashboard", file=sys.stderr)
        sys.exit(1)
    print(state["dash_dir"])


def cmd_add_issue(args):
    if len(args) < 3:
        print("Usage: dash add-issue <number> <title> <url>", file=sys.stderr)
        sys.exit(1)
    dash_dir = get_dash_dir()
    data = read_progress(dash_dir)
    if not data:
        sys.exit(1)

    number = int(args[0])
    title = args[1]
    url = args[2]
    if "issues" not in data:
        data["issues"] = []
    # Update if exists, otherwise add
    for issue in data["issues"]:
        if issue["number"] == number:
            issue["title"] = title
            issue["url"] = url
            write_progress(dash_dir, data)
            return
    data["issues"].append({
        "number": number,
        "title": title,
        "url": url,
        "status": "open",
    })
    write_progress(dash_dir, data)


def cmd_update_issue(args):
    if len(args) < 2:
        print("Usage: dash update-issue <number> <open|in_progress|closed>", file=sys.stderr)
        sys.exit(1)
    dash_dir = get_dash_dir()
    data = read_progress(dash_dir)
    if not data:
        sys.exit(1)

    number = int(args[0])
    status = args[1]
    for issue in data.get("issues", []):
        if issue["number"] == number:
            issue["status"] = status
            write_progress(dash_dir, data)
            return
    print(f"WARNING: Issue #{number} not found", file=sys.stderr)


def cmd_add_pr(args):
    if len(args) < 3:
        print("Usage: dash add-pr <number> <title> <url>", file=sys.stderr)
        sys.exit(1)
    dash_dir = get_dash_dir()
    data = read_progress(dash_dir)
    if not data:
        sys.exit(1)

    number = int(args[0])
    title = args[1]
    url = args[2]
    if "prs" not in data:
        data["prs"] = []
    # Update if exists, otherwise add
    for pr in data["prs"]:
        if pr["number"] == number:
            pr["title"] = title
            pr["url"] = url
            write_progress(dash_dir, data)
            return
    data["prs"].append({
        "number": number,
        "title": title,
        "url": url,
        "status": "open",
    })
    add_event(data, f"PR #{number} opened: {title}")
    write_progress(dash_dir, data)


def cmd_update_pr(args):
    if len(args) < 2:
        print("Usage: dash update-pr <number> <open|merged|closed>", file=sys.stderr)
        sys.exit(1)
    dash_dir = get_dash_dir()
    data = read_progress(dash_dir)
    if not data:
        sys.exit(1)

    number = int(args[0])
    status = args[1]
    for pr in data.get("prs", []):
        if pr["number"] == number:
            pr["status"] = status
            if status == "merged":
                add_event(data, f"PR #{number} merged: {pr['title']}")
            write_progress(dash_dir, data)
            return
    print(f"WARNING: PR #{number} not found", file=sys.stderr)


COMMANDS = {
    "init": cmd_init,
    "set-steps": cmd_set_steps,
    "step-start": cmd_step_start,
    "step-detail": cmd_step_detail,
    "step-link": cmd_step_link,
    "step-complete": cmd_step_complete,
    "step-error": cmd_step_error,
    "event": cmd_event,
    "add-issue": cmd_add_issue,
    "update-issue": cmd_update_issue,
    "add-pr": cmd_add_pr,
    "update-pr": cmd_update_pr,
    "check-control": cmd_check_control,
    "complete": cmd_complete,
    "error": cmd_error,
    "shutdown": cmd_shutdown,
    "dir": cmd_dir,
}


def main():
    if len(sys.argv) < 2 or sys.argv[1] not in COMMANDS:
        print("Usage: dash <command> [args...]", file=sys.stderr)
        print(f"Commands: {', '.join(COMMANDS.keys())}", file=sys.stderr)
        sys.exit(1)

    COMMANDS[sys.argv[1]](sys.argv[2:])


if __name__ == "__main__":
    main()
