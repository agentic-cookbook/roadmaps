#!/usr/bin/env python3
"""Deterministic step finder for feature roadmaps.

Reads a roadmap file, determines the next step via regex (no LLM),
and outputs the result as JSON. Does NOT launch agents — the calling
skill/agent handles that via the Agent tool.

Commands:
    coordinator next-step <roadmap-path>     Find the next non-complete, non-manual step
    coordinator resolve [feature-name]       Find and select a roadmap file
    coordinator summary <roadmap-path>       Print progress summary

Output is always JSON to stdout. Errors go to stderr.
"""

import json
import os
import re
import sys
from pathlib import Path


# --- Roadmap parsing ---

def parse_step_fields(block):
    """Extract key-value pairs from lines like '- **Key**: value'."""
    fields = {}
    for line in block.splitlines():
        m = re.match(r"^\s*-\s*\*\*(.+?)\*\*:\s*(.*)", line)
        if m:
            fields[m.group(1).strip()] = m.group(2).strip()
    return fields


def list_all_steps(roadmap_path):
    """Return all steps as a list of dicts."""
    content = Path(roadmap_path).read_text()
    step_pattern = re.compile(r"^### Step (\d+):\s*(.+)$", re.MULTILINE)
    matches = list(step_pattern.finditer(content))
    steps = []
    for i, match in enumerate(matches):
        block_start = match.end()
        block_end = matches[i + 1].start() if i + 1 < len(matches) else len(content)
        fields = parse_step_fields(content[block_start:block_end])
        steps.append({
            "step": int(match.group(1)),
            "description": match.group(2).strip(),
            "status": fields.get("Status", "Not Started").strip(),
            "type": fields.get("Type", "Auto").strip(),
            "issue": fields.get("GitHub Issue", ""),
            "complexity": fields.get("Complexity", ""),
        })
    return steps


def count_steps(roadmap_path):
    """Count total and complete steps."""
    content = Path(roadmap_path).read_text()
    total = len(re.findall(r"^### Step \d+:", content, re.MULTILINE))
    complete = len(re.findall(r"^\- \*\*Status\*\*:\s*Complete", content, re.MULTILINE | re.IGNORECASE))
    return total, complete


def find_roadmaps(base=".claude/Features/Active-Roadmaps"):
    """Find all active roadmaps with Phase: Ready."""
    roadmaps = []
    base_path = Path(base)
    if not base_path.exists():
        return roadmaps
    for f in sorted(base_path.glob("*-FeatureRoadmap.md")):
        content = f.read_text()
        phase_match = re.search(r"\*\*Phase\*\*:\s*(\w+)", content)
        status_match = re.search(r"^\*\*Status\*\*:\s*(.+)", content, re.MULTILINE)
        phase = phase_match.group(1) if phase_match else "Ready"
        status = status_match.group(1).strip() if status_match else "Not Started"
        if phase == "Ready" and status.lower() != "complete":
            name_match = re.search(r"^# Feature Roadmap:\s*(.+)", content, re.MULTILINE)
            name = name_match.group(1).strip() if name_match else f.stem.replace("-FeatureRoadmap", "")
            total, complete = count_steps(str(f))
            roadmaps.append({"name": name, "path": str(f), "total": total, "complete": complete})
    return roadmaps


def get_feature_name(roadmap_path):
    """Extract feature name from roadmap file."""
    content = Path(roadmap_path).read_text()
    m = re.search(r"^# Feature Roadmap:\s*(.+)", content, re.MULTILINE)
    return m.group(1).strip() if m else Path(roadmap_path).stem.replace("-FeatureRoadmap", "")


# --- Commands ---

def cmd_next_step(args):
    """Find the next non-complete, non-manual step."""
    if not args:
        print(json.dumps({"error": "Usage: coordinator next-step <roadmap-path>"}))
        sys.exit(1)

    roadmap_path = args[0]
    if not Path(roadmap_path).exists():
        print(json.dumps({"error": f"Roadmap not found: {roadmap_path}"}))
        sys.exit(1)

    steps = list_all_steps(roadmap_path)
    manual_skipped = []
    for s in steps:
        if s["status"].lower() == "complete":
            continue
        if s["type"].lower() == "manual":
            manual_skipped.append(s)
            continue
        # Found the next implementable step
        feature_name = get_feature_name(roadmap_path)
        total, complete = count_steps(roadmap_path)
        print(json.dumps({
            "action": "implement",
            "step": s["step"],
            "description": s["description"],
            "status": s["status"],
            "issue": s["issue"],
            "complexity": s["complexity"],
            "feature": feature_name,
            "roadmap": roadmap_path,
            "total": total,
            "complete": complete,
            "manual_skipped": manual_skipped,
        }))
        return

    # All done (or only manual steps left)
    feature_name = get_feature_name(roadmap_path)
    total, complete = count_steps(roadmap_path)
    print(json.dumps({
        "action": "done",
        "feature": feature_name,
        "roadmap": roadmap_path,
        "total": total,
        "complete": complete,
        "manual_skipped": manual_skipped,
    }))


def cmd_resolve(args):
    """Find and select a roadmap file."""
    feature_name = args[0] if args else None

    if feature_name:
        # Look for matching roadmap
        base = Path(".claude/Features/Active-Roadmaps")
        matches = list(base.glob(f"*{feature_name}*-FeatureRoadmap.md"))
        if len(matches) == 1:
            total, complete = count_steps(str(matches[0]))
            name = get_feature_name(str(matches[0]))
            print(json.dumps({"path": str(matches[0]), "name": name, "total": total, "complete": complete}))
        elif len(matches) > 1:
            results = []
            for m in matches:
                total, complete = count_steps(str(m))
                results.append({"path": str(m), "name": get_feature_name(str(m)), "total": total, "complete": complete})
            print(json.dumps({"choose": results}))
        else:
            print(json.dumps({"error": f"No roadmap matching '{feature_name}'"}))
            sys.exit(1)
    else:
        roadmaps = find_roadmaps()
        if len(roadmaps) == 0:
            print(json.dumps({"error": "No available roadmaps. Run /plan-roadmap first."}))
            sys.exit(1)
        elif len(roadmaps) == 1:
            print(json.dumps(roadmaps[0]))
        else:
            print(json.dumps({"choose": roadmaps}))


def cmd_summary(args):
    """Print progress summary."""
    if not args:
        print(json.dumps({"error": "Usage: coordinator summary <roadmap-path>"}))
        sys.exit(1)
    roadmap_path = args[0]
    steps = list_all_steps(roadmap_path)
    total, complete = count_steps(roadmap_path)
    feature_name = get_feature_name(roadmap_path)
    print(json.dumps({
        "feature": feature_name,
        "roadmap": roadmap_path,
        "total": total,
        "complete": complete,
        "steps": steps,
    }))


COMMANDS = {
    "next-step": cmd_next_step,
    "resolve": cmd_resolve,
    "summary": cmd_summary,
}


def main():
    if len(sys.argv) < 2 or sys.argv[1] not in COMMANDS:
        print(json.dumps({"error": f"Usage: coordinator <{'|'.join(COMMANDS.keys())}> [args...]"}))
        sys.exit(1)
    COMMANDS[sys.argv[1]](sys.argv[2:])


if __name__ == "__main__":
    main()
