#!/usr/bin/env python3
"""Show detailed info about a single active roadmap.

If multiple roadmaps exist, prints a numbered list for selection.
If only one exists, shows it directly. Prints all roadmap metadata,
the goal from the Feature Definition, and every step with full details.

Usage:
    describe-roadmap [feature-name]
"""

import json
import os
import re
import subprocess
import sys
from pathlib import Path

# Import shared roadmap library
sys.path.insert(0, str(Path(__file__).resolve().parent.parent.parent.parent / "scripts"))
sys.path.insert(0, str(Path.home() / ".claude" / "scripts"))
import roadmap_lib as lib

VERSION = "5"


def slugify(name):
    return re.sub(r"[^a-zA-Z0-9_-]", "-", name).strip("-").lower()


def get_dashboard_url_for(feature_name):
    """Find the dashboard URL for a specific feature by its slug directory."""
    tmpdir = Path(os.environ.get("TMPDIR", "/tmp")).resolve()
    dash_dir = tmpdir / f"progress-dashboard-{slugify(feature_name)}"
    port_file = dash_dir / "port"
    if not port_file.exists():
        return None
    try:
        port = int(port_file.read_text().strip())
    except (ValueError, OSError):
        return None
    if not (dash_dir / "progress.json").exists():
        return None
    # Check global state for pid match
    state_path = tmpdir / "progress-dashboard-active"
    if state_path.exists():
        try:
            state = json.loads(state_path.read_text())
            if str(dash_dir) == state.get("dash_dir"):
                pid = state.get("pid")
                if pid:
                    os.kill(pid, 0)
                    return f"http://127.0.0.1:{port}"
        except (json.JSONDecodeError, OSError):
            pass
    # Fallback: check if port is in use
    try:
        result = subprocess.run(
            ["lsof", "-ti", f":{port}"],
            capture_output=True, text=True, timeout=2,
        )
        if result.returncode == 0 and result.stdout.strip():
            return f"http://127.0.0.1:{port}"
    except (OSError, subprocess.TimeoutExpired):
        pass
    return None


def hyperlink(url, text=None):
    """Format a clickable terminal hyperlink using OSC 8."""
    label = text or url
    return f"\033]8;;{url}\033\\{label}\033]8;;\033\\"


STATUS_ICONS = {
    "complete": "+",
    "in progress": "~",
    "blocked": "!",
    "not started": "-",
}


def find_roadmaps():
    """Find all roadmap directories using the shared library."""
    return lib.find_roadmap_dirs(".")


def parse_header(roadmap_dir):
    """Extract metadata from a roadmap directory using frontmatter and state."""
    fields = {}
    roadmap_file = lib.roadmap_path(roadmap_dir)
    content = roadmap_file.read_text()
    meta, _ = lib.parse_frontmatter(roadmap_file)

    fields["name"] = lib.get_feature_name(roadmap_dir)
    fields["status"] = meta.get("status", lib.current_state(roadmap_dir))
    fields["phase"] = meta.get("phase", "")
    fields["created"] = meta.get("created", "")
    fields["state"] = lib.current_state(roadmap_dir)
    return fields, content


def parse_steps(content):
    step_pattern = re.compile(r"^### Step (\d+):\s*(.+)$", re.MULTILINE)
    matches = list(step_pattern.finditer(content))
    steps = []
    for i, match in enumerate(matches):
        block_start = match.end()
        block_end = matches[i + 1].start() if i + 1 < len(matches) else len(content)
        block = content[block_start:block_end]
        fields = {}
        for line in block.splitlines():
            m = re.match(r"^\s*-\s*\*\*(.+?)\*\*:\s*(.*)", line)
            if m:
                fields[m.group(1).strip()] = m.group(2).strip()
        steps.append({
            "num": int(match.group(1)),
            "desc": match.group(2).strip(),
            "status": fields.get("Status", "Not Started"),
            "issue": fields.get("GitHub Issue", ""),
            "type": fields.get("Type", "Auto"),
            "complexity": fields.get("Complexity", ""),
            "dependencies": fields.get("Dependencies", "None"),
            "pr": fields.get("PR", "_TBD_"),
        })
    return steps


def get_goal(roadmap_dir):
    """Read the Goal and Purpose section from the sibling Definition.md."""
    def_path = lib.definition_path(roadmap_dir)
    if not def_path.exists():
        return None
    content = def_path.read_text()
    goal_m = re.search(
        r"## Goal and Purpose\s*\n+(.+?)(?:\n\n|\n##|\Z)",
        content, re.DOTALL,
    )
    if not goal_m:
        return None
    return goal_m.group(1).strip()


def select_roadmap(roadmaps, arg=None):
    if arg:
        for r in roadmaps:
            name = lib.get_feature_name(r)
            if arg.lower() in name.lower():
                return r
        print(f"No roadmap matching '{arg}' found.")
        sys.exit(1)

    if len(roadmaps) == 1:
        return roadmaps[0]

    print("\nActive roadmaps:\n")
    for i, r in enumerate(roadmaps):
        name = lib.get_feature_name(r)
        total, complete = lib.count_steps(lib.roadmap_path(r))
        print(f"  {i + 1}. {name}  ({complete}/{total} done)")
    print(f"  q. Quit")

    try:
        choice = input("\nWhich roadmap? ")
    except EOFError:
        print("No input available. Pass feature name as argument.", file=sys.stderr)
        sys.exit(1)
    if choice.lower() == "q":
        sys.exit(0)
    try:
        idx = int(choice) - 1
        return roadmaps[idx]
    except (ValueError, IndexError):
        print("Invalid choice.")
        sys.exit(1)


def icon_for(status):
    return STATUS_ICONS.get(status.lower(), "?")


def print_roadmap(roadmap_dir):
    header, content = parse_header(roadmap_dir)
    steps = parse_steps(content)

    counts = {}
    for s in steps:
        key = s["status"].lower()
        counts[key] = counts.get(key, 0) + 1
    complete = counts.get("complete", 0)
    total = len(steps)

    # Version
    print(f"\n  describe-roadmap v{VERSION}\n")

    # Header
    print(f"  {header['name']}")
    print(f"  {'=' * len(header['name'])}")
    state = header.get('state', header.get('status', '?'))
    print(f"  State: {state}  |  Created: {header.get('created', '?')}")

    # Dashboard
    dashboard_url = get_dashboard_url_for(header["name"])
    if dashboard_url:
        print(f"  Dashboard: {hyperlink(dashboard_url)}")

    # Goal
    goal = get_goal(roadmap_dir)
    if goal:
        print(f"\n  {goal}")

    # Progress
    filled = round(20 * complete / total) if total else 0
    bar = "[" + "#" * filled + "-" * (20 - filled) + "]"
    parts = []
    for label, key in [("in progress", "in progress"), ("blocked", "blocked"), ("remaining", "not started")]:
        n = counts.get(key, 0)
        if n:
            parts.append(f"{n} {label}")
    extra = f"  ({', '.join(parts)})" if parts else ""
    print(f"\n  {bar}  {complete}/{total} done{extra}")

    # Steps
    print(f"\n  Steps:")
    for s in steps:
        issue = f"  {s['issue']}" if s['issue'] else ""
        pr = f"  PR: {s['pr']}" if s['pr'] and s['pr'] != "_TBD_" else ""
        deps = f"  deps: {s['dependencies']}" if s['dependencies'] != "None" else ""
        print(f"    [{icon_for(s['status'])}] {s['num']}. {s['desc']}  ({s['complexity']}){issue}{pr}{deps}")

    print()


def main():
    roadmaps = find_roadmaps()
    if not roadmaps:
        print("No active roadmaps found.")
        sys.exit(0)

    arg = sys.argv[1] if len(sys.argv) > 1 else None
    path = select_roadmap(roadmaps, arg)
    print_roadmap(path)

    # Prompt
    print("  Run /implement-roadmap now? [y/N]")


if __name__ == "__main__":
    main()
