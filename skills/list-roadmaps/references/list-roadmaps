#!/usr/bin/env python3
"""List active roadmaps with progress and description.

Scans .claude/Features/Active-Roadmaps/ and prints a concise summary
of each roadmap: progress bar, counts, and goal from the Feature Definition.

Usage:
    list-roadmaps
"""

import json
import os
import re
import sys
from pathlib import Path

VERSION = "4"

ACTIVE_DIR = Path(".claude/Features/Active-Roadmaps")
DEFS_DIR = Path(".claude/Features/FeatureDefinitions")


def get_dashboard_url():
    """Read the active dashboard URL from the state file, if running."""
    tmpdir = os.environ.get("TMPDIR", "/tmp")
    state_path = Path(tmpdir) / "progress-dashboard-active"
    if not state_path.exists():
        return None
    try:
        state = json.loads(state_path.read_text())
        port = state.get("port")
        pid = state.get("pid")
        if port and pid:
            # Check if process is still running
            try:
                os.kill(pid, 0)
                return f"http://127.0.0.1:{port}"
            except OSError:
                return None
    except (json.JSONDecodeError, KeyError):
        return None
    return None


def parse_roadmap(path):
    """Extract name, status, and step counts from a roadmap file."""
    content = path.read_text()
    name_m = re.search(r"^# Feature Roadmap:\s*(.+)", content, re.MULTILINE)
    name = name_m.group(1).strip() if name_m else path.stem.replace("-FeatureRoadmap", "")

    status_m = re.search(r"^\*\*Status\*\*:\s*(.+)", content, re.MULTILINE)
    status = status_m.group(1).strip() if status_m else "Unknown"

    step_pattern = re.compile(r"^### Step (\d+):\s*(.+)$", re.MULTILINE)
    matches = list(step_pattern.finditer(content))
    counts = {"complete": 0, "in progress": 0, "blocked": 0, "not started": 0}
    for i, match in enumerate(matches):
        block_start = match.end()
        block_end = matches[i + 1].start() if i + 1 < len(matches) else len(content)
        block = content[block_start:block_end]
        s_m = re.search(r"^\s*-\s*\*\*Status\*\*:\s*(.*)", block, re.MULTILINE)
        s = s_m.group(1).strip().lower() if s_m else "not started"
        counts[s] = counts.get(s, 0) + 1

    return name, status, len(matches), counts


def get_goal(feature_name):
    """Read the Goal and Purpose section from the Feature Definition."""
    def_path = DEFS_DIR / f"{feature_name}-FeatureDefinition.md"
    if not def_path.exists():
        return None
    content = def_path.read_text()
    goal_m = re.search(
        r"## Goal and Purpose\s*\n+(.+?)(?:\n\n|\n##|\Z)",
        content, re.DOTALL,
    )
    if not goal_m:
        return None
    first_line = goal_m.group(1).strip().split("\n")[0].strip()
    if len(first_line) > 120:
        first_line = first_line[:117] + "..."
    return first_line


def hyperlink(url, text=None):
    """Format a clickable terminal hyperlink using OSC 8."""
    label = text or url
    return f"\033]8;;{url}\033\\{label}\033]8;;\033\\"


def progress_bar(complete, total, width=20):
    filled = round(width * complete / total) if total else 0
    return "[" + "#" * filled + "-" * (width - filled) + "]"


def main():
    if not ACTIVE_DIR.exists():
        print("No active roadmaps found.")
        sys.exit(0)

    roadmaps = sorted(ACTIVE_DIR.glob("*-FeatureRoadmap.md"))
    if not roadmaps:
        print("No active roadmaps found.")
        sys.exit(0)

    dashboard_url = get_dashboard_url()

    print(f"\n  list-roadmaps v{VERSION}\n")
    for path in roadmaps:
        name, status, total, counts = parse_roadmap(path)
        complete = counts.get("complete", 0)
        bar = progress_bar(complete, total)

        remaining = []
        for label, key in [("in progress", "in progress"), ("blocked", "blocked"), ("remaining", "not started")]:
            n = counts.get(key, 0)
            if n:
                remaining.append(f"{n} {label}")

        print(f"  {name}  {bar}  {complete}/{total} done", end="")
        if remaining:
            print(f"  ({', '.join(remaining)})")
        else:
            print()

        goal = get_goal(name)
        if goal:
            print(f"    {goal}")
        if dashboard_url:
            print(f"    Dashboard: {hyperlink(dashboard_url)}")
        print()


if __name__ == "__main__":
    main()
