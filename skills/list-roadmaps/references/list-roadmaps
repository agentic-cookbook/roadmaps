#!/usr/bin/env python3
"""List active roadmaps with progress and description.

Scans Roadmaps/*/Roadmap.md and prints a concise summary
of each roadmap: progress bar, counts, and goal from the Feature Definition.

Usage:
    list-roadmaps
"""

import json
import os
import re
import sys
from pathlib import Path

# Import shared roadmap library
sys.path.insert(0, str(Path(__file__).resolve().parent.parent.parent.parent / "scripts"))
sys.path.insert(0, str(Path.home() / ".claude" / "scripts"))
import roadmap_lib as lib

VERSION = "6"


def slugify(name):
    return re.sub(r"[^a-zA-Z0-9_-]", "-", name).strip("-").lower()


def get_dashboard_url_for(feature_name):
    """Find the dashboard URL for a specific feature by its slug directory."""
    tmpdir = Path(os.environ.get("TMPDIR", "/tmp")).resolve()
    dash_dir = tmpdir / f"progress-dashboard-{slugify(feature_name)}"
    port_file = dash_dir / "port"
    pid_file = dash_dir / "server.pid"
    if not port_file.exists():
        return None
    try:
        port = int(port_file.read_text().strip())
    except (ValueError, OSError):
        return None
    # Check if the server process is alive via the progress.json (simpler than pid)
    # Try reading pid from the global state or checking if port responds
    progress = dash_dir / "progress.json"
    if not progress.exists():
        return None
    # Verify server is listening by checking if the pid from state file is alive
    state_path = tmpdir / "progress-dashboard-active"
    if state_path.exists():
        try:
            state = json.loads(state_path.read_text())
            if str(dash_dir) == state.get("dash_dir"):
                pid = state.get("pid")
                if pid:
                    os.kill(pid, 0)
                    return f"http://127.0.0.1:{port}"
        except (json.JSONDecodeError, OSError):
            pass
    # Fallback: check if any python process is serving this port
    # by looking for a server.py process in this dash_dir
    try:
        import subprocess
        result = subprocess.run(
            ["lsof", "-ti", f":{port}"],
            capture_output=True, text=True, timeout=2,
        )
        if result.returncode == 0 and result.stdout.strip():
            return f"http://127.0.0.1:{port}"
    except (OSError, subprocess.TimeoutExpired):
        pass
    return None


def parse_roadmap(roadmap_dir):
    """Extract name, state, and step counts from a roadmap directory."""
    name = lib.get_feature_name(roadmap_dir)
    state = lib.current_state(roadmap_dir)

    content = lib.roadmap_path(roadmap_dir).read_text()
    step_pattern = re.compile(r"^### Step (\d+):\s*(.+)$", re.MULTILINE)
    matches = list(step_pattern.finditer(content))
    counts = {"complete": 0, "in progress": 0, "blocked": 0, "not started": 0}
    for i, match in enumerate(matches):
        block_start = match.end()
        block_end = matches[i + 1].start() if i + 1 < len(matches) else len(content)
        block = content[block_start:block_end]
        s_m = re.search(r"^\s*-\s*\*\*Status\*\*:\s*(.*)", block, re.MULTILINE)
        s = s_m.group(1).strip().lower() if s_m else "not started"
        counts[s] = counts.get(s, 0) + 1

    return name, state, len(matches), counts


def get_goal(roadmap_dir):
    """Read the Goal and Purpose section from Roadmap.md."""
    rm_path = lib.roadmap_path(roadmap_dir)
    if not rm_path.exists():
        return None
    content = rm_path.read_text()
    goal_m = re.search(
        r"## Goal and Purpose\s*\n+(.+?)(?:\n\n|\n##|\Z)",
        content, re.DOTALL,
    )
    if not goal_m:
        return None
    first_line = goal_m.group(1).strip().split("\n")[0].strip()
    if len(first_line) > 120:
        first_line = first_line[:117] + "..."
    return first_line


def hyperlink(url, text=None):
    """Format a clickable terminal hyperlink using OSC 8."""
    label = text or url
    return f"\033]8;;{url}\033\\{label}\033]8;;\033\\"


def progress_bar(complete, total, width=20):
    filled = round(width * complete / total) if total else 0
    return "[" + "#" * filled + "-" * (width - filled) + "]"


def main():
    roadmap_dirs = lib.find_roadmap_dirs(".")
    if not roadmap_dirs:
        print("No active roadmaps found.")
        sys.exit(0)

    print(f"\n  list-roadmaps v{VERSION}\n")
    for roadmap_dir in roadmap_dirs:
        name, state, total, counts = parse_roadmap(roadmap_dir)
        complete = counts.get("complete", 0)
        bar = progress_bar(complete, total)

        remaining = []
        for label, key in [("in progress", "in progress"), ("blocked", "blocked"), ("remaining", "not started")]:
            n = counts.get(key, 0)
            if n:
                remaining.append(f"{n} {label}")

        display_state = "Running" if state == "Implementing" else state
        state_label = f"  [{display_state}]" if display_state else ""
        print(f"  {name}{state_label}  {bar}  {complete}/{total} done", end="")
        if remaining:
            print(f"  ({', '.join(remaining)})")
        else:
            print()

        goal = get_goal(roadmap_dir)
        if goal:
            print(f"    {goal}")
        dashboard_url = get_dashboard_url_for(name)
        if dashboard_url:
            print(f"    Dashboard: {hyperlink(dashboard_url)}")
        print()


if __name__ == "__main__":
    main()
