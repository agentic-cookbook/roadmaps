#!/usr/bin/env python3
"""Find the next step to implement from a Feature Roadmap file.

Reads the roadmap markdown, parses each step's **Status** field with regex,
and prints the lowest-numbered step that is not Complete.

Usage:
    next-step <path-to-roadmap.md>

Output:
    JSON object with step details, or {"done": true} if all steps are complete.

Example:
    $ next-step .claude/Features/Active-Roadmaps/MyFeature-FeatureRoadmap.md
    {"step": 1, "description": "Fix step ordering display", "status": "Not Started", "issue": "#17", "type": "Auto", "complexity": "M"}
"""

import json
import re
import sys
from pathlib import Path


def parse_step_fields(block):
    """Extract key-value pairs from lines like '- **Key**: value'."""
    fields = {}
    for line in block.splitlines():
        m = re.match(r"^\s*-\s*\*\*(.+?)\*\*:\s*(.*)", line)
        if m:
            fields[m.group(1).strip()] = m.group(2).strip()
    return fields


def main():
    if len(sys.argv) < 2:
        print(json.dumps({"error": "Usage: next-step <path-to-roadmap.md>"}))
        sys.exit(1)

    roadmap_path = Path(sys.argv[1])
    if not roadmap_path.exists():
        print(json.dumps({"error": f"Roadmap not found: {roadmap_path}"}))
        sys.exit(1)

    content = roadmap_path.read_text()
    step_pattern = re.compile(r"^### Step (\d+):\s*(.+)$", re.MULTILINE)
    matches = list(step_pattern.finditer(content))

    for i, match in enumerate(matches):
        step_num = int(match.group(1))
        step_desc = match.group(2).strip()

        block_start = match.end()
        block_end = matches[i + 1].start() if i + 1 < len(matches) else len(content)
        block = content[block_start:block_end]

        fields = parse_step_fields(block)
        status = fields.get("Status", "Not Started").strip()

        if status.lower() != "complete":
            result = {
                "step": step_num,
                "description": step_desc,
                "status": status,
                "issue": fields.get("GitHub Issue", ""),
                "type": fields.get("Type", "Auto"),
                "complexity": fields.get("Complexity", ""),
            }
            print(json.dumps(result))
            return

    print(json.dumps({"done": True}))


if __name__ == "__main__":
    main()
